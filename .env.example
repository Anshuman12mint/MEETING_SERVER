APP_NAME=meeting-server
APP_ENV=development
APP_VERSION=0.1.0
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
LOG_LEVEL=INFO
DOCS_ENABLED=true

DB_URL=sqlite+pysqlite:///./meeting_server.db
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
AUTO_INITIALIZE_SCHEMA=false
RUN_MIGRATIONS_ON_STARTUP=false

JWT_SECRET=change-this-secret-key-change-this-secret-key
JWT_ISSUER=college-server
JWT_AUDIENCE=college-clients
JWT_LEEWAY_SECONDS=5

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1,::1,testserver

ICE_SERVERS=stun:stun.l.google.com:19302
MEETING_IDLE_TIMEOUT_SECONDS=900
MAX_PARTICIPANTS_PER_MEETING=8
